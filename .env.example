NODE_ENV=development
PORT=3000
APP_NAME=nestjs-backend
API_PREFIX=api
LOG_LEVEL=log
DEFAULT_TIMEOUT_MS=30000
MONGO_URI=mongodb://localhost:27017/croper
SWAGGER_ENABLED=true
SWAGGER_PATH=docs
SWAGGER_TITLE='Croper API'
SWAGGER_DESCRIPTION='Croper backend API documentation'
SWAGGER_VERSION=1.0.0
SESSION_TOKEN_SECRET=change-me-session-token-secret-min-32
SESSION_TOKEN_EXPIRES_IN_SECONDS=900
REFRESH_TOKEN_SECRET=change-me-refresh-token-secret-min-32
REFRESH_TOKEN_EXPIRES_IN_SECONDS=604800
